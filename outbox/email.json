font-size:11px;color:#6b7280;\">Stop: <strong style=\"color:#111827;\">$204.00</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:center;\">TP1: <strong style=\"color:#111827;\">$240.00</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:center;\">TP2: <strong style=\"color:#111827;\">$260.00</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:right;\">TP3: <strong style=\"color:#111827;\">$285.00</strong></td>\n        </tr></table>\n      </td></tr></table>\n\n      <!-- LLY -->\n      <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"border:1px solid #e5e7eb;border-radius:8px;margin-bottom:12px;\"><tr><td style=\"padding:14px 16px;\">\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\"><tr>\n          <td><span style=\"font-size:16px;font-weight:700;\">LLY</span> <span style=\"margin-left:8px;padding:2px 8px;background:#d1fae5;color:#059669;border-radius:10px;font-size:11px;font-weight:600;\">&#10003; HOLD</span> <span style=\"font-size:10px;color:#9ca3af;\">price estimated</span></td>\n          <td align=\"right\" style=\"font-size:14px;font-weight:600;\">~$1,067 <span style=\"color:#dc2626;font-size:13px;\">~&#8722;0.3%</span></td>\n        </tr></table>\n        <p style=\"margin:8px 0 0;font-size:13px;color:#4b5563;line-height:1.5;\">Foundayo (orforglipron) FDA-approved April 1 and in pharmacies since April 9 — the oral GLP-1 launch catalyst is live. Q2 Foundayo revenue (~$220M per BofA) hits the books at Q2 earnings in ~July-August. Zero correlation to today's semi selloff — this is your portfolio risk anchor. TP1 at $1,114 is 4.4% away.</p>\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"margin-top:10px;\"><tr>\n          <td style=\"font-size:11px;color:#6b7280;\">Stop: <strong style=\"color:#111827;\">$915.00</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:center;\">TP1: <strong style=\"color:#111827;\">$1,114</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:center;\">TP2: <strong style=\"color:#111827;\">$1,243</strong></td>\n          <td style=\"font-size:11px;color:#6b7280;text-align:right;\">TP3: <strong style=\"color:#111827;\">$1,393</strong></td>\n        </tr></table>\n      </td></tr></table>\n\n      <!-- AVGO -->\n      <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"border:2px solid #fde68a;border-radius:8px;margin-bottom:12px;\"><tr><td style=\"padding:14px 16px;\">\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\"><tr>\n          <td><span style=\"font-size:16px;font-weight:700;\">AVGO</span> <span style=\"margin-left:8px;padding:2px 8px;background:#fef3c7;color:#d97706;border-radius:10px;font-size:11px;font-weight:600;\">&#9888; WATCH</span></td>\n          <td align=\"right\" style=\"font-size:14px;font-weight:600;\">$413.45 <span style=\"color:#dc2626;font-size:13px;\">&#8722;13.73%</span></td>\n        </tr></table>\n        <p style=\"margin:8px 0 0;font-size:13px;color:#4b5563;line-height:1.5;\">Earnings catalyst played (June 3). Beat: EPS $2.44 vs $2.32 (+5%), AI revenue +143% YoY — the business is on fire. Sold off because guidance NOT raised and CEO walked back from full AI systems to chips-only. Buy-the-rumor-sell-the-news. Back to near-entry.</p>\n        <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\" style=\"background:#fef9c3;border-left:3px solid #d97706;border-radius:4px;margin:8px 0;\"><tr><td style=\"padding:10px 12px;\">\n          <p style=\"margin:0 0 2px;font-size:12px;font-weight:600;color:#92400e;\">Commission rule — cannot exit profitably at current price:</p>\n          <p style=\"margin:0;font-size:12px;color:#78350f;font-family:'Courier New',monospace;\">Gross P&amp;L full exit: ($413.45 &#8722; $412.04) &#215; 0.315 = +